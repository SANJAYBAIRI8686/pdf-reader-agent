# Application Configuration
APP_NAME="AI Research Assistant"
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1

# Security
# Run `openssl rand -hex 32` to generate a strong secret key
JWT_SECRET=super-secret-jwt-signing-key-for-local-dev-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Database
# SQLite database path
DATABASE_URL=sqlite:///./research_assistant.db

# LLM Providers (OpenAI default, designed to support local Ollama)
OPENAI_API_KEY=your-openai-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Vector Database
CHROMA_DB_DIR=./chroma_data
CHROMA_COLLECTION_NAME=research_documents

# Storage Configuration
UPLOAD_DIR=./uploaded_files
MAX_UPLOAD_SIZE_MB=50
